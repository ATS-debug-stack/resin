{
	"extends": "@resin/typescript-config/tsconfig.frontend.json",
	"compilerOptions": {
		"moduleResolution": "bundler",
		"rootDirs": [
			".",
			"../@n8n/rest-api-client/src",
			"../@n8n/composables/src",
			"../@n8n/chat/src",
			"../@n8n/design-system/src"
		],
		"noEmit": true,
		"types": [
			"vitest/globals",
			"unplugin-icons/types/vue",
			"../@n8n/design-system/src/shims-modules.d.ts"
		],
		"paths": {
			"@/*": ["./src/*"],
			"@resin/rest-api-client*": ["../@n8n/rest-api-client/src*"],
			"@resin/composables*": ["../@n8n/composables/src*"],
			"@resin/constants*": ["../../@n8n/constants/src*"],
			"@resin/chat*": ["../@n8n/chat/src*"],
			"@resin/chat-hub*": ["../../@n8n/chat-hub/src*"],
			"@resin/design-system*": ["../@n8n/design-system/src*"],
			"@resin/i18n*": ["../@n8n/i18n/src*"],
			"@resin/stores*": ["../@n8n/stores/src*"],
			"@resin/api-types*": ["../../@n8n/api-types/src*"],
			"@resin/utils*": ["../../@n8n/utils/src*"],
			"@resin/expression-runtime": ["./vite/expression-runtime-stub.ts"]
		},
		// TODO: remove all options below this line
		"useUnknownInCatchVariables": false
	},
	"include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.vue"],
	"exclude": ["src/**/*.stories.ts", "src/plugins/codemirror/typescript/worker/**/*.d.ts"]
}
