{
  "name": "@resin/backend-common",
  "version": "1.21.0",
  "scripts": {
    "clean": "rimraf dist .turbo",
    "dev": "pnpm watch",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "format": "biome format --write .",
    "format:check": "biome ci .",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "watch": "tsc -p tsconfig.build.json --watch",
    "test": "jest",
    "test:unit": "jest",
    "test:dev": "jest --watch"
  },
  "main": "dist/index.js",
  "module": "src/index.ts",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "dependencies": {
    "@resin/config": "workspace:*",
    "@resin/constants": "workspace:*",
    "@resin/decorators": "workspace:*",
    "@resin/di": "workspace:*",
    "callsites": "catalog:",
    "flatted": "catalog:",
    "resin-workflow": "workspace:*",
    "stream-json": "catalog:",
    "picocolors": "catalog:",
    "reflect-metadata": "catalog:",
    "winston": "3.14.2",
    "yargs-parser": "21.1.1"
  },
  "devDependencies": {
    "@resin/typescript-config": "workspace:*",
    "@types/stream-json": "1.7.8",
    "@types/yargs-parser": "21.0.0",
    "zod": "catalog:"
  }
}
